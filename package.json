{
  "name": "amazon-scraper",
  "version": "3.3.0",
  "description": "High-performance containerized web scraper for Amazon (BSR, search, product detail) and generic dynamic pages. Built on Docker + Crawlee + Playwright.",
  "main": "assets/amazon_handler.js",
  "scripts": {
    "test": "node assets/main_handler.js https://www.amazon.com/zgbs/electronics",
    "setup": "bash scripts/setup.sh"
  },
  "keywords": [
    "amazon",
    "scraper",
    "asin",
    "bsr",
    "crawlee",
    "playwright",
    "openclaw",
    "docker"
  ],
  "author": "Joseph",
  "license": "MIT",
  "dependencies": {
    "playwright-extra": "^4.3.6",
    "playwright-extra-plugin-stealth": "^2.11.2",
    "playwright": "^1.40.0"
  },
  "openclaw": {
    "requires": {
      "docker": true
    },
    "requiredBinaries": ["docker"]
  }
}
